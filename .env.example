# ── Provider ──────────────────────────────────────────────────────────────────
# "ollama" | "openrouter" | "qwen" | "deepseek"
LLM_PROVIDER=deepseek

# ── Ollama (локально) ──────────────────────────────────────────────────────────
#LLM_PROVIDER=ollama
#OLLAMA_MODEL=llama3:8b
#OLLAMA_BASE_URL=http://localhost:11434/v1

# ── OpenRouter (облако) ────────────────────────────────────────────────────────
#LLM_PROVIDER=openrouter
#LLM_API_KEY=sk-or-v1-...
#OPENROUTER_MODEL=openai/gpt-4o

# ── Qwen (удалённый inference, OpenAI-совместимый) ────────────────────────────
#LLM_PROVIDER=qwen
#QWEN_API_KEY=your-qwen-api-key
#QWEN_BASE_URL=https://your-qwen-endpoint/v1
#QWEN_MODEL=llm

# ── DeepSeek (облако, OpenAI-совместимый) ─────────────────────────────────────
#LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# ── Elasticsearch / Kibana (опционально) ──────────────────────────────────────
#ELASTICSEARCH_URL=http://localhost:9200
#ELASTICSEARCH_INDEX_PREFIX=llm-extractor
#KIBANA_URL=http://localhost:5601

# ── Прочее ────────────────────────────────────────────────────────────────────
SEED_URL=http://example.gov.ru/o-departamente/rukovodstvo/
